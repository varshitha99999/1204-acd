    %{
    #include <stdio.h>
    #include <stdlib.h>
    #include <string.h>
    typedef struct node { char *val; struct node *l, *r; } node;
    node* mknode(char* val, node* l, node* r) {
        node* n = malloc(sizeof(node));
        n->val = strdup(val); n->l = l; n->r = r;
        return n;
    }
    void printTree(node* root, int lv) {
        if(!root) return;
        for(int i=0; i<lv; i++) printf("  ");
        printf("%s\n", root->val);
        printTree(root->l, lv+1); printTree(root->r, lv+1);
    }
    int yylex();
    void yyerror(char *s);
    %}
    %union { struct node *ptr; char *str; }
    %token <str> ATOM
    %type <ptr> exp
    %left '+' '-'
    %left '*'
    %%
    stmt: exp { printTree($1, 0); };
    exp: exp '+' exp { $$ = mknode("+", $1, $3); }

       | exp '*' exp { $$ = mknode("*", $1, $3); }
       | ATOM        { $$ = mknode($1, NULL, NULL); };
    %%
    void main() { printf("Enter expression: "); yyparse(); }
    void yyerror(char *s) { }

