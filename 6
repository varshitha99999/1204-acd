calc.l
    lex

    %{
    #include "y.tab.h"
    extern int yylval;
    %}
    %%
    [0-9]+ { yylval = atoi(yytext); return NUMBER; }
    [\t ]+ ;
    \n     { return 0; }
    .      { return yytext[0]; }
    %%
    int yywrap() { return 1; }

    
    calc.y
    yacc

    %{
    #include<stdio.h>
    int yylex();
    void yyerror(char *s);
    %}
    %token NUMBER
    %left '+' '-'
    %left '*'
    %%
    stmt: exp { printf("Result: %d\n", $1); };
    exp: exp '+' exp { $$ = $1 + $3; }

       | exp '-' exp { $$ = $1 - $3; }
       | exp '*' exp { $$ = $1 * $3; }
       | '(' exp ')' { $$ = $2; }
       | NUMBER      { $$ = $1; };
    %%
    void main() { printf("Enter expression: "); yyparse(); }
    void yyerror(char *s) { printf("Error\n"); }

    

